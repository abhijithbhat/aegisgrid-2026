{
  "name": "aegisgrid-2026",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run verify:env && npm run build && npm run check:size",
    "check:size": "node scripts/check-repo-size.mjs",
    "verify:env": "node scripts/verify-env.mjs",
    "load:test": "node scripts/load-test.mjs",
    "evals": "node evals/run.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^0.468.0",
    "next": "^16.2.10",
    "pdfjs-dist": "^5.4.394",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.4",
    "vitest": "^4.0.8",
    "wrangler": "^4.110.0"
  },
  "type": "module"
}
