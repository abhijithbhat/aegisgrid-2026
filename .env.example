# Server-only. Never expose this value through NEXT_PUBLIC_* variables.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
AI_TIMEOUT_MS=12000
AI_MAX_RETRIES=1

# Firestore uses Application Default Credentials on Google Cloud.
FIREBASE_PROJECT_ID=
ENABLE_FIRESTORE=false

# Public origin used for absolute metadata in production.
APP_ORIGIN=http://localhost:3000
